# Пример файла переменных окружения для локальной разработки
# Скопируйте этот файл как .env и заполните значения

# ===================================
# GitHub Actions (для CI/CD)
# ===================================

# Токен GitHub для автоматического деплоя
# Автоматически предоставляется GitHub Actions, не нужно заполнять
# GITHUB_TOKEN=автоматически

# ===================================
# Альтернативные хостинги (опционально)
# ===================================

# Netlify
# Получите на: https://app.netlify.com/user/applications/personal
# NETLIFY_AUTH_TOKEN=your_netlify_token_here
# NETLIFY_SITE_ID=your_site_id_here

# Vercel
# Получите на: https://vercel.com/account/tokens
# VERCEL_TOKEN=your_vercel_token_here
# VERCEL_ORG_ID=your_org_id_here
# VERCEL_PROJECT_ID=your_project_id_here

# Firebase
# Получите через: firebase login:ci
# FIREBASE_TOKEN=your_firebase_token_here

# itch.io Butler
# Получите на: https://itch.io/user/settings/api-keys
# BUTLER_API_KEY=your_butler_api_key_here

# ===================================
# Локальная разработка
# ===================================

# Порт для локального веб-сервера (по умолчанию: 8000)
# LOCAL_SERVER_PORT=8000

# Путь к Godot Engine (если не в PATH)
# GODOT_PATH=/path/to/Godot_v4.6-stable_linux.x86_64

# Директория для сборки (по умолчанию: build/web)
# BUILD_DIR=build/web

# ===================================
# Godot Engine
# ===================================

# Версия Godot для автосборки (настраивается в workflow)
# Изменяйте в .github/workflows/godot-web-export.yml
# GODOT_VERSION=4.6

# ===================================
# Дополнительные настройки
# ===================================

# Включить режим отладки (true/false)
# DEBUG_MODE=false

# Уровень логирования (info, debug, warn, error)
# LOG_LEVEL=info

# ===================================
# Примечания
# ===================================

# 1. Файл .env не должен попадать в git (добавлен в .gitignore)
# 2. Для GitHub Actions добавьте секреты через Settings → Secrets
# 3. Локально файл .env загружается автоматически (если используется)
# 4. Никогда не коммитьте реальные токены и ключи!
